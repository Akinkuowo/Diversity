generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                   @id @default(cuid())
  email                  String                   @unique
  password               String
  firstName              String
  lastName               String
  role                   UserRole                 @default(COMMUNITY_MEMBER)
  emailVerified          Boolean                  @default(false)
  verificationToken      String?
  resetPasswordToken     String?
  resetPasswordExpires   DateTime?
  gdprConsent            Boolean                  @default(false)
  gdprConsentDate        DateTime?
  twoFactorSecret        String?
  twoFactorEnabled       Boolean                  @default(false)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  department             String?
  announcements          Announcement[]
  business               Business?
  certificates           Certificate[]
  corporateVolunteerings CorporateVolunteering[]
  enrollments            Enrollment[]
  events                 Event[]
  eventRegistrations     EventRegistration[]
  forumComments          ForumComment[]
  forumLikes             ForumLike[]
  forumPosts             ForumPost[]
  learner                Learner?
  lessonCompletions      LessonCompletion[]
  notifications          Notification[]
  posts                  Post[]
  postLikes              PostLike[]
  postComments           PostComment[]
  quizResults            QuizResult[]
  resources              Resource[]
  testimonials           Testimonial[]
  achievements           UserAchievement[]
  profile                UserProfile?
  volunteer              Volunteer?
  notificationPrefs      NotificationPreferences?
  sessions               UserSession[]
  conversations          Conversation[]           @relation("ConversationParticipants")
  messagesSent           Message[]

  connectionsRequested Connection[]            @relation("Requester")
  connectionsReceived  Connection[]            @relation("Recipient")
  employedAtId         String?
  employedAt           Business?               @relation("BusinessEmployees", fields: [employedAtId], references: [id])
  applications         EmploymentApplication[]
}

model Connection {
  id          String   @id @default(cuid())
  requesterId String
  recipientId String
  status      String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("Requester", fields: [requesterId], references: [id])
  recipient User @relation("Recipient", fields: [recipientId], references: [id])

  @@unique([requesterId, recipientId])
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model NotificationPreferences {
  id               String   @id @default(cuid())
  userId           String   @unique
  communityUpdates Boolean  @default(true)
  weeklyDigest     Boolean  @default(true)
  mentionsReplies  Boolean  @default(true)
  directMessages   Boolean  @default(true)
  eventReminders   Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Post {
  id           String        @id @default(cuid())
  userId       String
  content      String
  images       String[]      @default([])
  location     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id])
  postLikes    PostLike[]
  postComments PostComment[]
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model PostComment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  bio          String?
  avatar       String?
  phone        String?
  address      String?
  city         String?
  country      String?
  dateOfBirth  DateTime?
  skills       String[]
  interests    String[]
  languages    String[]
  connections  Int       @default(0)
  impactPoints Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id])
}

model Business {
  id                    String                     @id @default(cuid())
  userId                String                     @unique
  companyName           String
  companyEmail          String
  companyPhone          String?
  website               String?
  industry              String
  size                  String
  description           String?
  logo                  String?
  address               String?
  city                  String?
  country               String?
  diversityCommitment   String?
  badgeLevel            BadgeLevel?                @default(SUPPORTER)
  verificationStatus    BusinessVerificationStatus @default(PENDING)
  verifiedAt            DateTime?
  csrReport             String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  user                  User                       @relation(fields: [userId], references: [id])
  corporateVolunteering CorporateVolunteering[]
  diversityPledge       DiversityPledge?
  sponsorships          Sponsorship[]
  testimonials          Testimonial[]
  employmentNotices     EmploymentNotice[]
  employees             User[]                     @relation("BusinessEmployees")
  courses               Course[]                   @relation("BusinessCourses")
  volunteerTasks        VolunteerTask[]            @relation("BusinessVolunteerTasks")
}

model DiversityPledge {
  id         String    @id @default(cuid())
  businessId String    @unique
  signedAt   DateTime  @default(now())
  content    String
  expiresAt  DateTime?
  business   Business  @relation(fields: [businessId], references: [id])
}

model CorporateVolunteering {
  id          String   @id @default(cuid())
  businessId  String
  volunteerId String
  hours       Int
  date        DateTime @default(now())
  project     String?
  createdAt   DateTime @default(now())
  business    Business @relation(fields: [businessId], references: [id])
  volunteer   User     @relation(fields: [volunteerId], references: [id])
}

model Course {
  id               String           @id @default(cuid())
  title            String
  description      String
  level            CourseLevel      @default(BEGINNER)
  duration         Int
  thumbnail        String?
  price            Float?           @default(0)
  isPublished      Boolean          @default(false)
  category         String
  tags             String[]
  videoUrl         String?
  cpdHours         Float?
  authorBusinessId String?
  type             String           @default("PUBLIC") // PUBLIC, INTERNAL
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  authorBusiness   Business?        @relation("BusinessCourses", fields: [authorBusinessId], references: [id])
  certificates     Certificate[]
  modules          CourseModule[]
  resources        CourseResource[]
  enrollments      Enrollment[]
  quizzes          Quiz[]
}

model CourseModule {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  videoUrl    String?
  content     String?
  duration    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id])
  lessons     Lesson[]
}

model Lesson {
  id          String             @id @default(cuid())
  moduleId    String
  title       String
  content     String?
  videoUrl    String?
  duration    Int?
  order       Int
  isPreview   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  module      CourseModule       @relation(fields: [moduleId], references: [id])
  completions LessonCompletion[]
}

model LessonCompletion {
  id          String    @id @default(cuid())
  lessonId    String
  userId      String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  lesson      Lesson    @relation(fields: [lessonId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([lessonId, userId])
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  progress    Float     @default(0)
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  expiresAt   DateTime?
  course      Course    @relation(fields: [courseId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model Certificate {
  id               String    @id @default(cuid())
  userId           String
  courseId         String
  certificateUrl   String
  issuedAt         DateTime  @default(now())
  expiryDate       DateTime?
  verificationCode String    @unique
  course           Course    @relation(fields: [courseId], references: [id])
  user             User      @relation(fields: [userId], references: [id])
}

model Quiz {
  id           String         @id @default(cuid())
  courseId     String
  title        String
  description  String?
  passingScore Int            @default(70)
  timeLimit    Int?
  attempts     Int            @default(1)
  createdAt    DateTime       @default(now())
  course       Course         @relation(fields: [courseId], references: [id])
  questions    QuizQuestion[]
  results      QuizResult[]
}

model QuizQuestion {
  id            String @id @default(cuid())
  quizId        String
  question      String
  type          String
  options       Json?
  correctAnswer String
  points        Int    @default(1)
  order         Int
  quiz          Quiz   @relation(fields: [quizId], references: [id])
}

model QuizResult {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  score       Int
  passed      Boolean
  startedAt   DateTime
  completedAt DateTime
  answers     Json
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Event {
  id            String              @id @default(cuid())
  title         String
  description   String
  type          String
  category      String
  startDate     DateTime
  endDate       DateTime
  location      String?
  online        Boolean             @default(false)
  meetingUrl    String?
  capacity      Int
  price         Float?              @default(0)
  status        EventStatus         @default(DRAFT)
  image         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  organizerId   String
  organizer     User                @relation(fields: [organizerId], references: [id])
  feedback      EventFeedback[]
  registrations EventRegistration[]
  tickets       Ticket[]
}

model Ticket {
  id                 String              @id @default(cuid())
  eventId            String
  type               TicketType          @default(FREE)
  name               String
  price              Float?              @default(0)
  quantity           Int
  available          Int
  description        String?
  salesStart         DateTime
  salesEnd           DateTime
  eventRegistrations EventRegistration[]
  event              Event               @relation(fields: [eventId], references: [id])
}

model EventRegistration {
  id           String    @id @default(cuid())
  eventId      String
  userId       String
  ticketId     String?
  qrCode       String
  checkedIn    Boolean   @default(false)
  checkedInAt  DateTime?
  registeredAt DateTime  @default(now())
  event        Event     @relation(fields: [eventId], references: [id])
  ticket       Ticket?   @relation(fields: [ticketId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model Volunteer {
  id                   String                @id @default(cuid())
  userId               String                @unique
  availability         String?
  interests            String[]
  skills               String[]
  totalHours           Int                   @default(0)
  createdAt            DateTime              @default(now())
  achievements         UserAchievement[]
  user                 User                  @relation(fields: [userId], references: [id])
  volunteerAssignments VolunteerAssignment[]
  hours                VolunteerHour[]
  tasks                VolunteerTask[]
}

model VolunteerTask {
  id             String                @id @default(cuid())
  title          String
  description    String
  project        String?
  startDate      DateTime
  endDate        DateTime?
  hours          Int
  status         TaskStatus            @default(OPEN)
  businessId     String?
  volunteerId    String?
  createdAt      DateTime              @default(now())
  business       Business?             @relation("BusinessVolunteerTasks", fields: [businessId], references: [id])
  assignments    VolunteerAssignment[]
  volunteerHours VolunteerHour[]
  volunteer      Volunteer?            @relation(fields: [volunteerId], references: [id])
}

model VolunteerAssignment {
  id          String           @id @default(cuid())
  taskId      String
  volunteerId String
  assignedAt  DateTime         @default(now())
  completedAt DateTime?
  status      AssignmentStatus @default(ASSIGNED)
  duty        String? // Assigned role/duty by the business
  task        VolunteerTask    @relation(fields: [taskId], references: [id])
  volunteer   Volunteer        @relation(fields: [volunteerId], references: [id])
}

model VolunteerHour {
  id          String         @id @default(cuid())
  volunteerId String
  taskId      String?
  hours       Int
  date        DateTime       @default(now())
  verified    Boolean        @default(false)
  verifiedBy  String?
  notes       String?
  createdAt   DateTime       @default(now())
  task        VolunteerTask? @relation(fields: [taskId], references: [id])
  volunteer   Volunteer      @relation(fields: [volunteerId], references: [id])
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String
  category    String
  fileUrl     String?
  content     String?
  language    String   @default("en")
  tags        String[]
  downloads   Int      @default(0)
  views       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
}

model CommunityProject {
  id           String        @id @default(cuid())
  title        String
  description  String
  goal         Float
  raised       Float         @default(0)
  category     String
  location     String?
  startDate    DateTime
  endDate      DateTime?
  status       ProjectStatus @default(PENDING)
  organization String
  contactEmail String
  image        String?
  createdAt    DateTime      @default(now())
  sponsorships Sponsorship[]
}

model Sponsorship {
  id              String            @id @default(cuid())
  businessId      String
  projectId       String
  amount          Float
  message         String?
  status          SponsorshipStatus @default(PENDING)
  sponsoredAt     DateTime          @default(now())
  approvedAt      DateTime?
  stripeSessionId String?           @unique
  business        Business          @relation(fields: [businessId], references: [id])
  project         CommunityProject  @relation(fields: [projectId], references: [id])
}

model ForumPost {
  id        String         @id @default(cuid())
  title     String
  content   String
  category  String
  tags      String[]
  views     Int            @default(0)
  isPinned  Boolean        @default(false)
  isLocked  Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  authorId  String
  comments  ForumComment[]
  likes     ForumLike[]
  author    User           @relation(fields: [authorId], references: [id])
}

model ForumComment {
  id        String    @id @default(cuid())
  content   String
  postId    String
  authorId  String
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  author    User      @relation(fields: [authorId], references: [id])
  post      ForumPost @relation(fields: [postId], references: [id])
}

model ForumLike {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime  @default(now())
  post      ForumPost @relation(fields: [postId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  type        String
  priority    String
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
}

model Achievement {
  id               String            @id @default(cuid())
  name             String
  description      String
  badge            String?
  points           Int               @default(10)
  type             String
  criteria         Json
  createdAt        DateTime          @default(now())
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  awardedAt     DateTime    @default(now())
  volunteerId   String?
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
  volunteer     Volunteer?  @relation(fields: [volunteerId], references: [id])

  @@unique([userId, achievementId])
}

model Testimonial {
  id         String    @id @default(cuid())
  content    String
  rating     Int?      @default(5)
  userId     String
  businessId String?
  isApproved Boolean   @default(false)
  createdAt  DateTime  @default(now())
  business   Business? @relation(fields: [businessId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
}

model ImpactMetric {
  id          String   @id @default(cuid())
  name        String
  value       Int
  category    String
  date        DateTime @default(now())
  description String?
}

model EmploymentNotice {
  id           String                  @id @default(cuid())
  businessId   String
  title        String
  description  String
  location     String?
  type         String // Full-time, Part-time, Remote, etc.
  salary       String?
  requirements String[]                @default([])
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  business     Business                @relation(fields: [businessId], references: [id])
  applications EmploymentApplication[]
}

model EmploymentApplication {
  id          String           @id @default(cuid())
  noticeId    String
  userId      String
  status      String           @default("PENDING") // PENDING, REVIEWING, ACCEPTED, REJECTED
  resumeUrl   String?
  coverLetter String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  notice      EmploymentNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id])

  @@unique([noticeId, userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model Conversation {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  participants  User[]    @relation("ConversationParticipants")
  messages      Message[]
  lastMessageAt DateTime  @default(now())
}

model Message {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  senderId       String
  conversationId String
  readBy         String[]     @default([])
  sender         User         @relation(fields: [senderId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Learner {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model CourseResource {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  type      String
  url       String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
}

model EventFeedback {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
}

enum UserRole {
  ADMIN
  VOLUNTEER
  BUSINESS
  LEARNER
  COMMUNITY_MEMBER
}

enum BadgeLevel {
  SUPPORTER
  INCLUSION_PARTNER
  CHAMPION
}

enum BusinessVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum TicketType {
  FREE
  PAID
}

enum TaskStatus {
  OPEN
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  DECLINED
  IN_PROGRESS
  PENDING_COMPLETION
  COMPLETED
  CANCELLED
}

enum ProjectStatus {
  PENDING
  APPROVED
  FUNDED
  COMPLETED
  CANCELLED
}

enum SponsorshipStatus {
  PENDING
  APPROVED
  COMPLETED
  CANCELLED
}
